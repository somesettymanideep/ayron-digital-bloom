Options -MultiViews
DirectorySlash Off

RewriteEngine On

# Force HTTPS and non-www
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.ayrondigitalsolutions\.com [NC]
RewriteRule ^(.*)$ https://ayrondigitalsolutions.com/$1 [L,R=301]

# Remove index.php from URL
RewriteCond %{THE_REQUEST} /index\.php [NC]
RewriteRule ^(.*)index\.php$ /$1 [R=301,L]

# If URL points to a real directory without trailing slash, serve its index.html
# INTERNALLY (no redirect) so /vijayawada returns 200 directly, matching canonical.
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+?)/?$ /$1/index.html [L]

# SPA fallback - serve root index.html for any unmatched route
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]
